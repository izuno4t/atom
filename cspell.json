{
  "version": "0.2",
  "language": "en,ja",
  "useGitignore": true,
  "ignorePaths": [
    "target/**",
    "Cargo.lock",
    "baselines/**",
    "tests/fixtures/**"
  ],
  "dictionaryDefinitions": [
    {
      "name": "atom-project",
      "path": "./cspell-project-words.txt",
      "addWords": true
    }
  ],
  "dictionaries": [
    "atom-project"
  ],
  "files": [
    "**/*.md",
    "**/*.rs",
    "**/*.toml",
    "**/*.yml",
    "**/*.yaml"
  ],
  "ignoreRegExpList": [
    "/https?:\\/\\/[^\\s)]+/g",
    "/[A-Za-z]:\\\\[^\\s]+/g"
  ]
}

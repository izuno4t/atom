input_dir = "/path/to/input-directory"
inventory_out = "benchmark/reports/markitdown-inventory.tsv"
markdown_output_root = "benchmark/outputs/markitdown"
per_file_timeout_seconds = 180
retry_statuses = ""
inspection_out = "benchmark/reports/markitdown-inspection.tsv"
inspection_report = "benchmark/reports/markitdown-report.md"
inspection_source_timeout_seconds = 120
atom_command = "target/debug/atom"
atom_inventory_out = "benchmark/reports/atom-inventory.tsv"
atom_markdown_output_root = "benchmark/outputs/atom"
atom_per_file_timeout_seconds = 180
atom_retry_statuses = ""
atom_inspection_out = "benchmark/reports/atom-inspection.tsv"
atom_report = "benchmark/reports/atom-report.md"
comparison_report = "benchmark/reports/atom-vs-markitdown-report.md"
